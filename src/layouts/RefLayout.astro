---
interface Props {
  title: string;
  fonts?: string;
  cacheControl?: boolean;
}

const { title, fonts = 'Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600', cacheControl = false } = Astro.props;
const siteBase = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  {cacheControl && <meta http-equiv="Cache-Control" content="no-store" />}
  <title>{title}</title>
  <script is:inline define:vars={{ siteBase }}>
    window.__siteBase = siteBase;
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href={`https://fonts.googleapis.com/css2?family=${fonts}&display=swap`} rel="stylesheet" />
  <link rel="stylesheet" href={`${siteBase}/assets/css/styles.css`} />
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
