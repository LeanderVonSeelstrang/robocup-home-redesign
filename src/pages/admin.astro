---
import RefLayout from '../layouts/RefLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<RefLayout title="Admin — RoboCup@Home Scoring">
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/admin.css`} />
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/poster.css`} />

  <!-- LOGIN SCREEN -->
  <div id="screen-login" class="login-screen" hidden>
    <div class="login-card">
      <div class="login-logo">RoboCup@Home</div>
      <div class="login-title">Admin</div>
      <form id="login-form" autocomplete="on">
        <div class="field">
          <label>Email</label>
          <input type="email" id="login-email" autocomplete="email" required>
        </div>
        <div class="field">
          <label>Password</label>
          <input type="password" id="login-password" autocomplete="current-password" required>
        </div>
        <div id="login-error" class="login-error" hidden></div>
        <button type="submit" class="btn-primary" id="login-btn" style="width:100%">Sign in</button>
      </form>
    </div>
  </div>

  <!-- ADMIN APP (hidden until authenticated) -->
  <div id="admin-app" hidden>
  <div id="navbar"></div>
  <header id="topbar">
    <button id="back-btn" class="btn-icon" hidden title="Go back">←</button>
    <span id="breadcrumb"></span>
    <button id="logout-btn" class="btn-ghost btn-logout" title="Sign out">Sign out</button>
  </header>

  <!-- SCREEN: Competitions -->
  <div id="screen-competitions" class="screen" hidden>
    <div class="screen-header">
      <h2>Competitions</h2>
      <button class="btn-primary" id="new-comp-btn">+ New Competition</button>
    </div>

    <form id="comp-form" class="card form-card" hidden>
      <h3 id="comp-form-title">New Competition</h3>
      <div class="field" id="comp-id-field">
        <label>Competition ID <span class="hint">(e.g. go2026)</span></label>
        <input type="text" id="comp-id" placeholder="go2026" required>
      </div>
      <div class="field">
        <label>Name</label>
        <input type="text" id="comp-name" placeholder="German Open 2026" required>
      </div>
      <div class="field-row">
        <div class="field">
          <label>City</label>
          <input type="text" id="comp-city" placeholder="Hannover">
        </div>
        <div class="field">
          <label>Country</label>
          <input type="text" id="comp-country" placeholder="Germany">
        </div>
        <div class="field field-narrow">
          <label>Year</label>
          <input type="number" id="comp-year" placeholder="2026">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Start date</label>
          <input type="date" id="comp-start-date">
        </div>
        <div class="field">
          <label>End date</label>
          <input type="date" id="comp-end-date">
        </div>
      </div>
      <div class="field">
        <label>Timezone <span class="hint">(IANA — auto-filled from country)</span></label>
        <input type="text" id="comp-timezone" placeholder="Europe/Berlin" list="timezone-list" autocomplete="off">
        <datalist id="timezone-list">
          <option value="Europe/Berlin"></option>
          <option value="Europe/London"></option>
          <option value="Europe/Paris"></option>
          <option value="Europe/Lisbon"></option>
          <option value="Europe/Madrid"></option>
          <option value="Europe/Rome"></option>
          <option value="Europe/Amsterdam"></option>
          <option value="Europe/Vienna"></option>
          <option value="Europe/Warsaw"></option>
          <option value="Europe/Prague"></option>
          <option value="Europe/Budapest"></option>
          <option value="Europe/Bucharest"></option>
          <option value="Europe/Istanbul"></option>
          <option value="Europe/Athens"></option>
          <option value="Europe/Helsinki"></option>
          <option value="Europe/Stockholm"></option>
          <option value="Europe/Oslo"></option>
          <option value="Europe/Copenhagen"></option>
          <option value="Europe/Zurich"></option>
          <option value="Europe/Brussels"></option>
          <option value="America/New_York"></option>
          <option value="America/Chicago"></option>
          <option value="America/Denver"></option>
          <option value="America/Los_Angeles"></option>
          <option value="America/Sao_Paulo"></option>
          <option value="America/Buenos_Aires"></option>
          <option value="America/Toronto"></option>
          <option value="America/Mexico_City"></option>
          <option value="America/Bogota"></option>
          <option value="America/Lima"></option>
          <option value="America/Santiago"></option>
          <option value="Asia/Tokyo"></option>
          <option value="Asia/Seoul"></option>
          <option value="Asia/Shanghai"></option>
          <option value="Asia/Hong_Kong"></option>
          <option value="Asia/Singapore"></option>
          <option value="Asia/Bangkok"></option>
          <option value="Asia/Dubai"></option>
          <option value="Asia/Kolkata"></option>
          <option value="Asia/Karachi"></option>
          <option value="Asia/Taipei"></option>
          <option value="Australia/Sydney"></option>
          <option value="Australia/Melbourne"></option>
          <option value="Pacific/Auckland"></option>
          <option value="Africa/Cairo"></option>
          <option value="Africa/Johannesburg"></option>
          <option value="Africa/Nairobi"></option>
          <option value="UTC"></option>
        </datalist>
      </div>
      <div class="field">
        <label>Livestream URL <span class="hint">(e.g. https://www.youtube.com/@channel/live)</span></label>
        <input type="url" id="comp-stream-url" placeholder="https://www.youtube.com/@RoboCupHome/live">
      </div>
      <div class="field">
        <label>Referee PIN <span class="hint">(required to open the referee dashboard)</span></label>
        <input type="text" id="comp-referee-pin" placeholder="e.g. robot2026" autocomplete="off" maxlength="32">
      </div>
      <div class="field">
        <label class="checkbox-label">
          <input type="checkbox" id="comp-active" checked>
          <span>Active</span>
        </label>
        <div class="field-hint">Active competitions appear in the referee dashboard and live display.</div>
      </div>
      <div class="field">
        <label class="checkbox-label">
          <input type="checkbox" id="comp-public-scoresheets">
          <span>Public score sheets (read-only)</span>
        </label>
        <div class="field-hint">Let anyone open score sheets in read-only mode (no login). Editing stays referee-only — scores can never be changed by visitors.</div>
      </div>
      <div class="field">
        <label class="checkbox-label">
          <input type="checkbox" id="comp-show-results-qr">
          <span>Show results QR on display</span>
        </label>
        <div class="field-hint">Add a QR code to the /display rotation linking to this competition's public results page.</div>
      </div>
      <div class="field" id="comp-podium-section" hidden>
        <label>Podium <span class="hint">(legacy competitions without run data)</span></label>
        <div id="comp-podium-list" style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px"></div>
        <button type="button" id="add-podium-btn" class="btn-ghost" style="font-size:0.8rem;padding:4px 10px">+ Add entry</button>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn-primary">Create</button>
        <button type="button" class="btn-ghost" id="cancel-comp-btn">Cancel</button>
      </div>
    </form>

    <div id="comp-list" class="item-list"></div>
    <div id="comp-inactive-toggle" class="inactive-toggle" hidden></div>
  </div>

  <!-- SCREEN: Schedule -->
  <div id="screen-schedule" class="screen screen-schedule" hidden>
    <div class="card form-card sched-controls-card">
      <div class="field-row" style="align-items:flex-end">
        <div class="field field-narrow">
          <label>Venue opens</label>
          <input type="time" id="venue-open">
        </div>
        <div class="field field-narrow">
          <label>Venue closes</label>
          <input type="time" id="venue-close">
        </div>
        <button type="button" class="btn-ghost" id="sched-apply-btn">Apply</button>
        <div style="flex:1"></div>
        <button type="button" class="btn-ghost" id="sched-balance-btn">⇄ Balance Arenas</button>
        <button type="button" class="btn-ghost" id="sched-settings-btn">⚙ Settings</button>
      </div>
    </div>

    <div id="sched-no-dates" class="card" style="text-align:center;padding:48px 24px;color:var(--muted)" hidden>
      <div style="margin-bottom:16px">Set competition start and end dates to build a schedule.</div>
      <button type="button" class="btn-ghost" id="sched-edit-dates-btn">Edit competition dates</button>
    </div>

    <div id="sched-main" class="sched-main" hidden>
      <div class="sched-sidebar" id="sched-sidebar">
        <div id="sched-test-cards" class="sched-test-cards"></div>
      </div>
      <div class="sched-grid-outer" id="sched-grid-outer"></div>
    </div>
  </div>

  <!-- SCREEN: Slots (Settings) -->
  <div id="screen-slots" class="screen" hidden>
    <div class="screen-header">
      <h2 id="slots-title">Slots</h2>
      <div style="display:flex;gap:8px">
        <button class="btn-ghost" id="live-control-btn">◉ Live control</button>
        <button class="btn-primary" id="new-slot-btn">Edit Schedule</button>
      </div>
    </div>

    <div class="card form-card" id="arenas-card">
      <h3>Arenas</h3>
      <div id="arena-chips" class="arena-chips"></div>
      <div class="field-row" style="margin-top:10px">
        <div class="field">
          <input type="text" id="new-arena-name" placeholder="e.g. Arena Blue">
        </div>
        <button type="button" class="btn-ghost" id="add-arena-btn">+ Add</button>
      </div>
    </div>

    <div class="card form-card" id="teams-card">
      <h3>Participating Teams</h3>
      <div id="comp-team-chips" class="arena-chips"></div>
      <div class="field" style="margin-top:10px;position:relative">
        <input type="text" id="comp-team-search" placeholder="Search team name…" autocomplete="off">
        <div id="comp-team-results" class="team-search-dropdown" hidden></div>
      </div>
    </div>

    <div class="card form-card" id="tests-card">
      <h3>Tests</h3>
      <div id="test-list" class="test-list"></div>
      <label class="test-upload-btn">
        + Upload .tex scoresheet
        <input type="file" id="test-file-input" accept=".tex" style="display:none" multiple>
      </label>
    </div>
  </div>

  <!-- SCREEN: Slot Teams -->
  <div id="screen-teams" class="screen" hidden>
    <div class="screen-header">
      <h2 id="teams-title">Teams</h2>
      <div style="display:flex;gap:8px;align-items:center">
        <button class="btn-ghost" id="poster-manage-btn" hidden>Manage Session →</button>
        <button class="btn-primary" id="add-team-btn">+ Add Team</button>
      </div>
    </div>

    <div id="team-picker" class="card form-card" hidden>
      <h3>Add Team</h3>
      <div class="field">
        <label>Search team</label>
        <input type="text" id="team-search" placeholder="Type team name…" autocomplete="off">
      </div>
      <div id="team-results" class="team-results"></div>
    </div>

    <div id="team-list" class="item-list"></div>

    <div class="card form-card" style="margin-top:24px">
      <h3>Referee</h3>
      <div class="field">
        <input type="text" id="slot-referee-input" placeholder="Referee name (optional)" autocomplete="off">
      </div>
    </div>

    <div id="slot-link-box" class="card" style="margin-top:24px">
      <div class="slot-link-label">Referee link for this slot</div>
      <div id="slot-link" class="slot-link-url"></div>
    </div>
  </div>

  <!-- POSTER SESSION MANAGEMENT SCREEN -->
  <div id="screen-poster" class="screen" hidden>
    <div class="screen-header">
      <h2 id="poster-title">Poster Session</h2>
    </div>
    <div id="poster-links-section">
      <div class="poster-section-title">Judge Links</div>
      <div id="poster-links-grid" class="poster-links-grid"></div>
    </div>
    <div id="poster-matrix-section">
      <div class="poster-section-title">Scoring Progress</div>
      <div id="poster-matrix"></div>
    </div>
  </div>

  <!-- SCREEN: Live control -->
  <div id="screen-live" class="screen" hidden>
    <div class="screen-header">
      <h2>Live control</h2>
      <button class="btn-danger" id="close-all-runs-btn">Close all running runs</button>
    </div>
    <div class="card form-card">
      <h3>Now on display</h3>
      <div class="field-hint" style="margin-bottom:12px">The run each arena's /display is currently showing live. Click "End" to force it off the display.</div>
      <div id="live-now-list" class="live-now-list"></div>
    </div>
  </div>

  <!-- Close-all-running confirmation overlay -->
  <div id="close-runs-overlay" class="test-preview-overlay" hidden>
    <div class="test-preview-modal">
      <div class="test-preview-header">
        <div>
          <div class="test-preview-title">Close all running runs</div>
          <div class="test-preview-meta">Emergency use only — this should almost never be needed.</div>
        </div>
        <button class="btn-icon" id="close-runs-modal-close" title="Close">×</button>
      </div>
      <div class="test-preview-body">
        <p style="color:var(--penalty);font-size:0.85rem;margin:0 0 12px">
          This force-closes every run below so it stops showing on /display. It does <strong>not</strong> submit a score
          — closed runs won't appear on the results leaderboard. A referee still scoring will re-open theirs automatically on their next edit.
        </p>
        <div id="close-runs-list" class="live-now-list"></div>
      </div>
      <div class="test-preview-actions">
        <button class="btn-danger" id="close-runs-confirm">Close ALL running</button>
        <button class="btn-ghost"   id="close-runs-cancel">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Test preview overlay -->
  <div id="test-preview-overlay" class="test-preview-overlay" hidden>
    <div class="test-preview-modal">
      <div class="test-preview-header">
        <div>
          <div id="test-preview-title" class="test-preview-title"></div>
          <div id="test-preview-meta"  class="test-preview-meta"></div>
        </div>
        <div style="display:flex;gap:6px;align-items:center;">
          <button class="btn-ghost btn-sm" id="test-preview-json-toggle">{ } JSON</button>
          <button class="btn-icon" id="test-preview-close" title="Close">×</button>
        </div>
      </div>
      <div id="test-preview-body" class="test-preview-body"></div>
      <pre id="test-preview-json" class="test-preview-json" hidden></pre>
      <div id="test-preview-actions" class="test-preview-actions" hidden>
        <button class="btn-primary" id="test-preview-save">Add to competition</button>
        <button class="btn-ghost"   id="test-preview-cancel">Cancel</button>
      </div>
    </div>
  </div>

  </div><!-- /#admin-app -->

  <script is:inline type="module" src={`${base}/assets/referee-tool/js/admin.js`}></script>
</RefLayout>
