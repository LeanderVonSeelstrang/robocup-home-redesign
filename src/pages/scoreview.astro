---
import RefLayout from '../layouts/RefLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<RefLayout
  title="Score View — RoboCup@Home"
  fonts="Space+Mono:wght@400;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400"
>
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/scoreview.css`} />

  <div id="loading">Loading…</div>

  <div id="app" hidden>
    <header id="view-header">
      <a id="back-link" href="#" class="view-nav-link">← Back</a>
      <div id="header-center">
        <div id="test-name">—</div>
        <div id="team-name">—</div>
      </div>
      <div id="total-display">
        <span id="total-score">0</span>
        <span class="total-label">pts</span>
      </div>
    </header>

    <main id="view-body"></main>

    <div id="notes-section" hidden>
      <div class="notes-label">Notes</div>
      <div id="notes-text" class="notes-text"></div>
    </div>
  </div>

  <script is:inline type="module" src={`${base}/assets/referee-tool/js/scoreview.js`}></script>
</RefLayout>
