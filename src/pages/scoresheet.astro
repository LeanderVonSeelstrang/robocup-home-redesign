---
import RefLayout from '../layouts/RefLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<RefLayout
  title="Score Sheet — RoboCup@Home"
  fonts="Space+Mono:wght@400;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400"
  cacheControl={true}
>
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/shared.css`} />
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/scoresheet.css`} />

  <!-- Referee login overlay -->
  <div id="referee-login-overlay" class="ref-login-overlay" hidden>
    <div class="ref-login-card">
      <div class="ref-login-title">Referee Sign In</div>
      <div class="ref-login-sub">RoboCup@Home Scoring</div>
      <form id="referee-login-form">
        <input type="email"    id="referee-login-email"    class="ref-login-input" placeholder="Email" required autocomplete="email">
        <input type="password" id="referee-login-password" class="ref-login-input" placeholder="Password" required autocomplete="current-password">
        <div id="referee-login-error" class="ref-login-error" hidden></div>
        <button type="submit" id="referee-login-btn" class="ref-login-btn">Sign in</button>
      </form>
    </div>
  </div>

  <div id="loading">Loading…</div>

  <div id="app" hidden>
    <div id="connection-status" class="status-banner" style="display:none;"></div>
    
    <header id="sheet-header">
      <a id="back-link" class="sheet-nav-link">← Back</a>
      <div id="header-left">
        <span id="test-name">—</span>
        <span id="team-name">—</span>
      </div>
      <div id="header-right">
        <div id="main-timer-wrap">
          <span id="timer">—</span>
          <div class="timer-ctrl-btns">
            <button id="timer-start-btn" class="timer-ctrl-btn" title="Start / Pause">▶</button>
            <button id="timer-reset-btn" class="timer-ctrl-btn" title="Reset">↺</button>
          </div>
        </div>
        <div id="total-display">
          <span id="total-score">0</span>
          <span class="total-label">pts</span>
        </div>
        <div id="team-nav">
          <a id="prev-team-link" class="sheet-nav-link" hidden>← Prev</a>
          <a id="next-team-link" class="sheet-nav-link" hidden>Next →</a>
        </div>
      </div>
    </header>

    <div id="aux-timers">
      <div class="aux-timer-card">
        <div class="aux-timer-label">30 sec rule</div>
        <span class="aux-timer-display" id="timer-30s">0:30</span>
        <div class="timer-ctrl-btns">
          <button class="timer-ctrl-btn" id="t30-start" title="Start / Pause">▶</button>
          <button class="timer-ctrl-btn" id="t30-reset"  title="Reset">↺</button>
        </div>
      </div>
      <div class="aux-timer-card">
        <div class="aux-timer-label">1 min restart</div>
        <span class="aux-timer-display" id="timer-1min">1:00</span>
        <div class="timer-ctrl-btns">
          <button class="timer-ctrl-btn" id="t1m-start" title="Start / Pause">▶</button>
          <button class="timer-ctrl-btn" id="t1m-reset"  title="Reset">↺</button>
        </div>
      </div>
    </div>

    <main id="sheet-body"></main>

    <footer id="sheet-footer">
      <textarea id="notes" placeholder="Notes for this run…"></textarea>
      <div id="footer-bar">
        <div id="save-status"></div>
        <div id="footer-actions">
          <button id="reset-btn" class="btn-reset" title="Reset score sheet">↺ Reset</button>
          <button id="submit-btn">Submit Score Sheet</button>
        </div>
      </div>
    </footer>

    <div id="reset-confirm" class="reset-confirm" hidden>
      <div class="reset-confirm-box">
        <p>Reset this score sheet? All scores and notes will be cleared.</p>
        <div class="reset-confirm-actions">
          <button id="reset-confirm-ok" class="btn-reset-ok">Reset</button>
          <button id="reset-confirm-cancel" class="btn-reset-cancel">Cancel</button>
        </div>
      </div>
    </div>

    <div id="unlock-confirm" class="unlock-confirm" hidden>
      <div class="unlock-confirm-box">
        <p>Are you sure you want to unlock the score sheet and allow further edits?</p>
        <div class="unlock-confirm-actions">
          <button id="unlock-confirm-ok" class="btn-unlock-ok">Unlock</button>
          <button id="unlock-confirm-cancel" class="btn-unlock-cancel">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline type="module" src={`${base}/assets/referee-tool/js/scoresheet.js`}></script>
</RefLayout>
