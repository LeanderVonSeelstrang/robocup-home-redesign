---
import RefLayout from '../layouts/RefLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<RefLayout title="Referee Dashboard — RoboCup@Home" cacheControl={true}>
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/shared.css`} />
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/dashboard.css`} />

  <!-- Referee login overlay -->
  <div id="referee-login-overlay" class="ref-login-overlay" hidden>
    <div class="ref-login-card">
      <div class="ref-login-title">Referee Sign In</div>
      <div class="ref-login-sub">RoboCup@Home Scoring</div>
      <form id="referee-login-form">
        <input type="email"    id="referee-login-email"    class="ref-login-input" placeholder="Email" required autocomplete="email">
        <input type="password" id="referee-login-password" class="ref-login-input" placeholder="Password" required autocomplete="current-password">
        <div id="referee-login-error" class="ref-login-error" hidden></div>
        <button type="submit" id="referee-login-btn" class="ref-login-btn">Sign in</button>
      </form>
    </div>
  </div>

  <div id="navbar"></div>
  <header id="topbar">
    <a class="ref-menu-link" href={`${base}/referee`}>← Menu</a>
    <div id="comp-name">RoboCup@Home</div>
    <div id="topbar-sub">Referee Dashboard</div>
    <button id="ref-signout-btn" class="ref-signout-btn" title="Sign out" hidden>Sign out</button>
  </header>

  <!-- Competition picker -->
  <div id="screen-picker" hidden>
    <div class="section-label">Select Competition</div>
    <div id="comp-list"></div>
  </div>

  <!-- PIN screen -->
  <div id="screen-pin" hidden>
    <div class="pin-card">
      <div class="pin-title">Referee Access</div>
      <div class="pin-sub">Enter the referee PIN for <strong id="pin-comp-name"></strong></div>
      <form id="pin-form">
        <input type="text" id="pin-input" class="pin-input" placeholder="PIN" autocomplete="off" autocapitalize="none">
        <div id="pin-error" class="pin-error" hidden>Incorrect PIN.</div>
        <button type="submit" class="btn-primary" style="width:100%">Enter</button>
      </form>
    </div>
  </div>

  <!-- Slot list -->
  <div id="screen-slots" hidden>
    <div id="filter-bar" hidden>
      <div id="arena-filter" class="filter-row"></div>
      <div id="referee-filter" class="filter-row"></div>
    </div>
    <div id="dash-lb-panel" class="dash-lb-panel" hidden>
      <button id="dash-lb-toggle" class="dash-lb-toggle" type="button">
        <span class="dash-lb-title">Standings</span>
        <span class="dash-lb-chevron">▼</span>
      </button>
      <div id="dash-lb-list" class="dash-lb-list"></div>
    </div>

    <div id="slot-groups"></div>

    <div id="inspection-panel" class="insp-panel" hidden>
      <div class="insp-panel-header">
        <span class="insp-panel-title">Robot Inspection — Quick Access</span>
        <span class="insp-panel-hint">Any team · use for retakes</span>
      </div>
      <div class="insp-panel-teams"></div>
    </div>
  </div>

  <div id="loading">Loading…</div>

  <script is:inline type="module" src={`${base}/assets/referee-tool/js/dashboard.js`}></script>
</RefLayout>
