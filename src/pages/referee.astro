---
import RefLayout from '../layouts/RefLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Destination cards. `param` is the query key each page expects for the
// selected competition (dashboard/display/queue use `competition`, results uses `id`).
const links = [
  { id: 'dashboard', page: 'dashboard', param: 'competition', label: 'Dashboard', desc: 'Score runs, manage slots and inspections', wide: true },
  { id: 'display',   page: 'display',   param: 'competition', label: 'Display',   desc: 'Public live scoreboard for the arena screen' },
  { id: 'streaming', page: 'streaming', param: 'competition', label: 'Stream Overlay', desc: 'Transparent OBS overlay for the stream' },
  { id: 'queue',     page: 'queue',     param: 'competition', label: 'Queue',     desc: 'Upcoming runs and inspection status' },
  { id: 'results',   page: 'results',   param: 'id',          label: 'Results',   desc: 'Overall standings and per-test scores' },
];
---
<RefLayout title="Referee Tool — RoboCup@Home">
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/shared.css`} />
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/referee.css`} />

  <!-- Referee/admin login overlay (shared markup expected by ensureRefereeAuth) -->
  <div id="referee-login-overlay" class="ref-login-overlay" hidden>
    <div class="ref-login-card">
      <div class="ref-login-title">Referee Sign In</div>
      <div class="ref-login-sub">RoboCup@Home Scoring</div>
      <form id="referee-login-form">
        <input type="email"    id="referee-login-email"    class="ref-login-input" placeholder="Email" required autocomplete="email">
        <input type="password" id="referee-login-password" class="ref-login-input" placeholder="Password" required autocomplete="current-password">
        <div id="referee-login-error" class="ref-login-error" hidden></div>
        <button type="submit" id="referee-login-btn" class="ref-login-btn">Sign in</button>
      </form>
    </div>
  </div>

  <main class="ref-landing">
    <header class="ref-landing-header">
      <h1>Referee Tool</h1>
      <p>RoboCup@Home scoring &amp; competition control</p>
    </header>

    <div class="ref-auth-bar">
      <span id="ref-auth-status" class="ref-auth-status">—</span>
      <button id="ref-signin-btn"  class="ref-menu-link" hidden>Sign in</button>
      <button id="ref-signout-btn" class="ref-menu-link" hidden>Sign out</button>
    </div>

    <div class="ref-comp-picker">
      <label for="comp-select">Competition</label>
      <select id="comp-select" disabled>
        <option>Loading…</option>
      </select>
    </div>

    <nav class="ref-landing-grid" id="ref-landing-grid" aria-busy="true">
      {links.map((l) => (
        <a class:list={["ref-landing-card", "is-disabled", { "ref-landing-card--wide": l.wide }]} id={`card-${l.id}`} data-page={l.page} data-param={l.param} aria-disabled="true">
          <span class="ref-landing-label">{l.label}</span>
          <span class="ref-landing-desc">{l.desc}</span>
        </a>
      ))}
    </nav>

    <!-- Admin-only: revealed by referee.js when the signed-in account has the `admin` claim -->
    <section id="ref-admin-section" hidden>
      <div class="ref-section-label">Admin</div>
      <nav class="ref-landing-grid">
        <a class="ref-landing-card" id="card-admin" href={`${base}/admin`}>
          <span class="ref-landing-label">Admin Console</span>
          <span class="ref-landing-desc">Manage competitions, teams, tests &amp; schedule</span>
        </a>
        <div class="ref-final-card">
          <span class="ref-landing-label">Final result duration</span>
          <span class="ref-landing-desc">How long Display &amp; Stream hold the result after submit — 0 disables it</span>
          <div class="ref-final-row">
            <input id="final-secs" type="number" min="0" max="120" step="0.5" value="10" />
            <span class="ref-final-unit">seconds</span>
            <span id="final-secs-status" class="ref-final-status" aria-live="polite"></span>
          </div>
        </div>
        <div class="ref-final-card">
          <span class="ref-landing-label">Stream overlay size</span>
          <span class="ref-landing-desc">How much width the /streaming text blocks use — 30–100%</span>
          <div class="ref-final-row">
            <input id="stream-occupancy" type="number" min="30" max="100" step="5" value="100" />
            <span class="ref-final-unit">%</span>
            <span id="stream-occupancy-status" class="ref-final-status" aria-live="polite"></span>
          </div>
        </div>
        <div class="ref-final-card">
          <span class="ref-landing-label">Info background opacity</span>
          <span class="ref-landing-desc">How opaque/black the /streaming info boxes are — 30–100% (higher = less transparent)</span>
          <div class="ref-final-row">
            <input id="stream-pill-opacity" type="number" min="30" max="100" step="5" value="72" />
            <span class="ref-final-unit">%</span>
            <span id="stream-pill-opacity-status" class="ref-final-status" aria-live="polite"></span>
          </div>
        </div>
      </nav>
    </section>
  </main>

  <script is:inline type="module" src={`${base}/assets/referee-tool/js/referee.js`}></script>
</RefLayout>
