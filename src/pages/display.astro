---
import RefLayout from '../layouts/RefLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<RefLayout
  title="Live Score Display — RoboCup@Home"
  fonts="Space+Mono:wght@400;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400"
  cacheControl={true}
>
  <link slot="head" rel="stylesheet" href={`${base}/assets/referee-tool/css/display.css`} />

  <div id="screen-loading" class="centered-screen">
    <span>Connecting…</span>
  </div>

  <div id="screen-comp" class="picker-screen" hidden>
    <div class="picker-wrap">
      <div class="picker-heading">Live Display</div>
      <div class="picker-sub">Select a competition</div>
      <div id="comp-list" class="picker-list"></div>
    </div>
  </div>

  <div id="screen-arena" class="picker-screen" hidden>
    <div class="picker-wrap">
      <button class="picker-back" id="back-to-comp">← Back</button>
      <div class="picker-heading" id="arena-comp-name">—</div>
      <div class="picker-sub">Select an arena</div>
      <div id="arena-list" class="picker-list"></div>
    </div>
  </div>

  <div id="screen-waiting" hidden>
    <div id="waiting-arena-badge"></div>
    <div id="waiting-msg">Waiting for an active run…</div>
    <button class="picker-back" id="change-arena-btn">← Change Arena</button>
  </div>

  <div id="screen-idle" hidden>
    <header id="idle-header">
      <span id="idle-arena-badge" class="arena-badge"></span>
      <span id="idle-slide-title" class="idle-slide-title">—</span>
      <div id="idle-dots" class="idle-dots"></div>
      <button class="picker-back" id="idle-change-btn">← Arena</button>
    </header>
    <div id="idle-slide-body" class="idle-slide-body"></div>
    <div id="idle-progress-bar"><div id="idle-progress-fill"></div></div>
  </div>

  <div id="screen-live" hidden>
    <div id="run-status-bar" hidden>
      <span id="run-status-text">Run complete — waiting for next run</span>
    </div>
    <header id="display-header">
      <div id="display-meta">
        <span id="display-arena-badge" class="arena-badge"></span>
        <span id="display-test-name">—</span>
      </div>
      <div id="display-team-name">—</div>
      <button class="picker-back" id="live-change-btn">← Arena</button>
    </header>

    <div id="big-cards">
      <div class="big-card" id="score-card">
        <div class="big-card-label">Score</div>
        <div class="big-card-value" id="live-score">0</div>
        <div class="big-card-unit">pts</div>
      </div>
      <div class="big-card" id="timer-card">
        <div class="big-card-label">Time</div>
        <div class="big-card-value" id="live-timer">—</div>
        <div class="big-card-unit" id="timer-status"></div>
      </div>
      <div class="big-card restart-card" id="restart-card" hidden>
        <div class="big-card-label">Restart</div>
        <div class="big-card-value" id="restart-timer">—</div>
        <div class="big-card-unit" id="restart-status"></div>
      </div>
    </div>

    <div id="feed-section">
      <div id="feed-heading">Scoring Activity</div>
      <div id="feed-list"></div>
      <div id="feed-empty">Waiting for scoring actions…</div>
    </div>
  </div>

  <script is:inline type="module" src={`${base}/assets/referee-tool/js/display.js`}></script>
</RefLayout>
