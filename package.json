{
  "name": "robocup-home",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "local": "bash scripts/local.sh",
    "local:fresh": "bash scripts/local.sh --fresh",
    "emulator": "firebase emulators:start --project robocup-home --export-on-exit=./emulator-data $([ -d emulator-data ] && echo --import=./emulator-data)",
    "seed": "cd scripts && npm run seed:emulator"
  },
  "dependencies": {
    "astro": "^7.0.3",
    "firebase": "^12.0.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true,
    "@firebase/util@1.15.1": true,
    "esbuild@0.28.1": true
  }
}
