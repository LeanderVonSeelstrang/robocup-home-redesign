rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────────────────────
    // Admin: account carries the `admin` custom claim. Grant it with
    // scripts/set-admin-claim.js (works against the emulator or, with a
    // service-account key, production).
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Referee or admin: signed in with email/password (not anonymous).
    // Admins also satisfy this (they sign in with password), so they keep
    // run/inspection write access in addition to the admin-only collections.
    function isReferee() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'password';
    }

    // ── TEAMS ─────────────────────────────────────────────────────────
    // Public read (used by public site, admin team search).
    // Admin-only write.
    match /teams/{teamId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── COMPETITIONS ──────────────────────────────────────────────────
    // Public read (liveview, event overview, dashboard).
    // Admin-only write (create, edit, delete competitions).
    match /competitions/{compId} {
      allow read:  if true;
      allow write: if isAdmin();

      // Tests: public read, admin write
      match /tests/{testId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      // Slots: public read, admin write
      match /slots/{slotId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      // Runs: public read (liveview needs scores + timer state),
      //       email-authenticated users can write (referees + admins).
      match /runs/{runId} {
        allow read:  if true;
        allow write: if isReferee();

        // Scoring activity feed: one immutable doc per event (append-only). Kept in a
        // subcollection so run docs stay small and unrelated pages don't download it.
        // Public read (display/overlay), referee write.
        match /feed/{eventId} {
          allow read:  if true;
          allow write: if isReferee();
        }
      }

      // Inspections: public read (queue view), referee write.
      match /inspections/{teamId} {
        allow read:  if true;
        allow write: if isReferee();
      }
    }
  }
}
