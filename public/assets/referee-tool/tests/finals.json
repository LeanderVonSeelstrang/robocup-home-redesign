{
  "testId": "finals",
  "name": "Finals",
  "timeLimit": 10,
  "sections": [
    {
      "id": "main_goal",
      "heading": "Main Goal (can be repeated)",
      "items": [
        {
          "id": "find_problem",
          "type": "count",
          "maxCount": 3,
          "points": 150,
          "label": "Find and clearly state an encountered problem",
          "penalties": [
            { "id": "repeated_find",   "type": "fixed", "points": 100, "label": "Find repeated problem category" },
            { "id": "asking_location", "type": "fixed", "points": 150, "label": "Human assistance: Asking for location of a problem" }
          ]
        },
        {
          "id": "solve_problem",
          "type": "count",
          "maxCount": 10,
          "points": 650,
          "label": "Solve a problem",
          "penalties": [
            { "id": "solved_repeat_2nd", "type": "fixed",      "points": 300, "label": "Solving repeated problem category for the 2nd time" },
            { "id": "solved_repeat_3rd", "type": "fixed",      "points": 500, "label": "Solving repeated problem category for the 3rd (or more) time" },
            { "id": "instructing_human", "type": "percentage",                "label": "Instructing a human to perform parts of the task (% of item score)" }
          ]
        },
        {
          "id": "gpsr_partial_note",
          "type": "info",
          "label": "Solving only parts of a GPSR command applies a percentage penalty according to similar scores in other tests — record it via the instructing-human % above / in the remarks."
        },
        {
          "id": "moving_basket",
          "type": "boolean",
          "points": 600,
          "label": "Moving the laundry basket"
        },
        {
          "id": "open_door",
          "type": "boolean",
          "points": 600,
          "label": "Opening the Door of the Apartment"
        },
        {
          "id": "close_dishwasher",
          "type": "boolean",
          "points": 300,
          "label": "Closing the Dishwasher"
        },
        {
          "id": "custom_note",
          "type": "info",
          "label": "Custom tasks (approved by the TC) are scored at their agreed point value — record them in the remarks; the fixed-point sheet cannot represent arbitrary custom points."
        }
      ]
    },
    {
      "id": "penalties",
      "heading": "Penalties",
      "items": [
        { "id": "restart", "type": "standalone_penalty", "maxCount": 1, "points": 50, "label": "Restart (only applies if the robot continues scoring afterwards)" }
      ]
    }
  ]
}
